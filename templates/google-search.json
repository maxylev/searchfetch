{
  "name": "google-search",
  "description": "Google web search results",
  "order": 6,
  "url_patterns": [
    "^https?://(www\\.)?google\\.[^/]+/search\\?"
  ],
  "url_template": "https://www.google.com/search?udm=14&q={query}&hl={hl}&gl={gl}",
  "url_params": {
    "query": {
      "required": true,
      "description": "Search query string",
      "encode": "url"
    },
    "hl": {
      "required": false,
      "default": "en",
      "description": "Interface language (e.g., 'en', 'de', 'fr', 'ja')"
    },
    "gl": {
      "required": false,
      "default": "us",
      "description": "Country code for result localization (e.g., 'us', 'de', 'jp')"
    }
  },
  "cookies": [
    {
      "name": "CONSENT",
      "value": "YES+cb.20250101-01-p0.en+FX+999",
      "domain": ".google.com",
      "path": "/"
    }
  ],
  "block_resources": [
    "image",
    "media",
    "font",
    "stylesheet"
  ],
  "remove": [
    "script",
    "style",
    "svg",
    "img",
    "nav",
    "footer"
  ],
  "sections": [
    {
      "name": "Results",
      "selector": "div[data-snc]:has(h3), div.g:has(h3), a:has(h3), h3",
      "multiple": true,
      "max_items": 10,
      "children": [
        {
          "name": "Title",
          "selector": "h3, " ,
          "format": "text"
        },
        {
          "name": "URL",
          "selector": "a:has(h3), a",
          "format": "attribute",
          "attribute": "href",
          "transform": "decode_google_url"
        },
        {
          "name": "Snippet",
          "selector": "[data-sncf] span, [data-sncf]",
          "format": "text"
        }
      ]
    }
  ]
}
